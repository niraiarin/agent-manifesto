*.olean
*.ilean
*.trace
*.c.hash
*.olean.hash
*.ilean.hash
*.olean.lock
*.olean.trace

# OS
.DS_Store

# Review logs (large HTML exports)
*.html
!docs/graph-view/*.html
design-implementation-plan-workspace/
.claude/metrics/*.jsonl
!.claude/metrics/v5-approvals.jsonl
!.claude/metrics/v7-tasks.jsonl
!.claude/metrics/decision-log.jsonl
!.claude/metrics/assumptions.jsonl

# Auto-generated plugin distribution
dist/*
!dist/agent-manifesto-plugin/
.claude/worktrees/
scripts/__pycache__/
*.bak
*.bak-*

# Depgraph snapshots (generated by scripts/depgraph.sh)
depgraph-[0-9]*.json
.cascade-state/
.claude/metrics/cycle-check-runs/

# Session handoffs are runtime ephemera — keep .gitkeep + .archive/ structure
# but exclude the actual session-state files. Resume bookmarks (md) and JSONL
# event logs are local-only; they are not load-bearing for the repo.
.claude/handoffs/handoff-*.jsonl
.claude/handoffs/handoff-resume-*.md
.claude/handoffs/handoff-resume-*.md.injected
.claude/handoffs/.archive/
