{
  "namespace": "CreditRisk",
  "assumptions": {
    "C": [
      {
        "id": "C1",
        "source": "humanDecision",
        "content": "融資判断の最終責任は審査担当者にある"
      },
      {
        "id": "C2",
        "source": "humanDecision",
        "content": "反社会的勢力との取引を排除する"
      },
      {
        "id": "C3",
        "source": "humanDecision",
        "content": "AIの判断根拠を金融庁に説明可能にする"
      },
      {
        "id": "C4",
        "source": "humanDecision",
        "content": "個人情報保護法・銀行法に準拠する"
      },
      {
        "id": "C5",
        "source": "humanDecision",
        "content": "信用スコアの算出に人種・性別を使用しない"
      },
      {
        "id": "C6",
        "source": "humanDecision",
        "content": "デフォルト率の年間目標は1%以下"
      },
      {
        "id": "C7",
        "source": "humanDecision",
        "content": "リスク評価モデルの更新は四半期ごとに実施する"
      }
    ],
    "H": [
      {
        "id": "H1",
        "basis": "C6",
        "refutation": "マクロ経済が根本的に不安定化した場合",
        "content": "過去の財務データからデフォルト確率を統計的に予測可能"
      },
      {
        "id": "H2",
        "basis": "C3",
        "refutation": "XAI技術の限界が判明した場合",
        "content": "SHAP値による特徴量重要度の説明が規制要件を満たす"
      },
      {
        "id": "H3",
        "basis": "C5",
        "refutation": "公正性の定義が変更された場合",
        "content": "公正性メトリクス（Demographic Parity等）で偏り検出可能"
      },
      {
        "id": "H4",
        "basis": "C7",
        "refutation": "リアルタイムモデル更新が必須になった場合",
        "content": "四半期更新で十分な精度を維持できる"
      },
      {
        "id": "H5",
        "basis": "C6",
        "refutation": "非財務データの重要性が支配的になった場合",
        "content": "財務諸表の3期分で基本的な信用評価が可能"
      },
      {
        "id": "H6",
        "basis": "H1",
        "refutation": "産業構造の急変で業種分類が無効化された場合",
        "content": "業種別のデフォルト率ベンチマークが参照可能"
      }
    ]
  },
