  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "電気的特性（寄生容量・抵抗・電磁干渉）は物理法則に従い、設計ルールで管理しなければならない"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "TSMCのN5プロセスのDesign Rule Manual（DRM）に準拠する"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "設計フローはCadence Virtuosoをベースとする"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "DRCチェックは全レイヤー（Metal、Via、Poly等）を対象とする"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "フルチップDRCを1時間以内に完了させたい"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C2"
          ],
          "refutation": "DRMのバージョンアップでルールが大幅に変更される場合"
        }
      },
      "content": "N5プロセスではマルチパターニング（SADP/SAQP）のルールが最も複雑で違反が多い"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C3"
          ],
          "refutation": "Synopsys ICValidatorの方がN5プロセスとの親和性が高い場合"
        }
      },
      "content": "Cadence PVSがVirtuosoフローと最も統合されたDRCエンジン"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "ルール間の相互作用が複雑でAIによる分類が不十分な場合"
        }
      },
      "content": "過去の違反パターンを学習し、違反しやすい箇所を優先的にチェックすることで効率化可能"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "チップ面積が極端に大きい場合、並列化の通信オーバーヘッドが支配的になる"
        }
      },
      "content": "チップ領域を分割して並列DRCを実行することで処理時間を線形にスケールダウン可能"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C4",
            "C5"
          ],
          "refutation": "インクリメンタルチェックの差分検出が不完全で見逃しが発生する場合"
        }
      },
      "content": "変更箇所のみをインクリメンタルにチェックすることで再チェック時間を90%削減可能"
    }
  ]
}
