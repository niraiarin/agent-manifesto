  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "著作権法に基づき、楽曲の無断利用は侵害に該当する"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "私的利用・引用・パロディ等の権利制限規定（フェアユース）を正しく除外する"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "JASRAC・NexTone等の管理楽曲データベースとの照合を基本とする"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "音声フィンガープリント技術（Chromaprint等）を検知エンジンの核とする"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "メロディの類似度判定にはピッチシーケンスの動的時間伸縮法を使用する"
    },
    {
      "id": "C6",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q6",
          "date": "2026-03-26"
        }
      },
      "content": "侵害検知時はまず通知を送り、一定期間の異議申立て猶予を設ける"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C3"
          ],
          "refutation": "管理団体に登録されていないインディーズ楽曲が大量に存在する場合"
        }
      },
      "content": "管理楽曲データベースのカバー率は商業音楽の95%以上である"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C4",
            "C5"
          ],
          "refutation": "楽曲のリミックスやマッシュアップがフィンガープリントの照合を困難にする場合"
        }
      },
      "content": "フィンガープリントとメロディ類似度の二段階判定で検知精度を向上できる"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C6"
          ],
          "refutation": "異議申立て件数が多すぎて対応コストが運用を圧迫する場合"
        }
      },
      "content": "段階的エスカレーション（通知→警告→削除）が法的リスクを最小化する"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "環境音やノイズが多い録音で誤検知率が許容範囲を超える場合"
        }
      },
      "content": "SNR（信号対雑音比）に基づく前処理で誤検知を大幅に低減できる"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C5",
            "C6"
          ],
          "refutation": "ジャンルごとのメロディパターンの類似性が高く閾値設定が困難な場合"
        }
      },
      "content": "ジャンル別の類似度閾値の動的調整が誤検知と見逃しのトレードオフを最適化する"
    }
  ]
}
