  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "修復後の画像には修復箇所を明示するメタデータを付与し、原本との区別を保証する"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "修復で存在しない人物・建物・文字を追加してはならない。欠損部分は推定として明示する"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "銀塩写真の経年劣化（褪色・銀鏡・カビ）の種類ごとに修復手法を分ける"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "修復前の原画像を常に保持し、修復処理は非破壊で行う"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "修復結果は原画像との比較スライダーで表示し、修復度合いを調整可能にする"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C3"
          ],
          "refutation": "全劣化タイプに対して単一の修復アルゴリズムが有効な場合"
        }
      },
      "content": "褪色修復にはチャンネル別ヒストグラム補正、銀鏡にはinpaintingが適切"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C1",
            "C3"
          ],
          "refutation": "AIによる補完が歴史考証的に検証不可能な場合"
        }
      },
      "content": "大規模欠損部分の補完には拡散モデルが有効だが、推定であることの確信度を出力すべき"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "リアルタイム処理が不要な場合"
        }
      },
      "content": "高解像度スキャン画像の処理にはタイル分割とGPU並列化が必要"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "ユーザが技術的パラメータに関心がない場合"
        }
      },
      "content": "修復パラメータ（ノイズ除去強度・色温度補正量）の詳細表示オプションが上級ユーザに有用"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C5",
            "C1"
          ],
          "refutation": "カラー化の需要がない場合"
        }
      },
      "content": "モノクロ写真のカラー化は修復とは別機能として提供し、推定であることを明示すべき"
    }
  ]
}
