  "assumptions": {
    "C": [
      {
        "id": "C1",
        "source": "humanDecision",
        "content": "要約は原著作物の引用範囲内に留め、全文書き起こしは行わない"
      },
      {
        "id": "C2",
        "source": "humanDecision",
        "content": "配信者のオプトアウト要求には即時対応する"
      },
      {
        "id": "C3",
        "source": "humanDecision",
        "content": "要約に含まれる発言は文脈を歪めない"
      },
      {
        "id": "C4",
        "source": "humanDecision",
        "content": "要約の長さは原音声の10%以内とする"
      }
    ],
    "H": [
      {
        "id": "H1",
        "basis": "C2,外部知識",
        "refutation": "音声認識精度が言語・方言で大幅に低下",
        "content": "音声認識モデルは主要言語で十分な精度を持つ"
      },
      {
        "id": "H2",
        "basis": "C3,H1",
        "refutation": "話者分離が不正確で発言の帰属を誤る",
        "content": "複数話者の分離・識別は実用水準で可能"
      },
      {
        "id": "H3",
        "basis": "C1,H1",
        "refutation": "専門用語の多い分野で要約品質が著しく低下",
        "content": "ドメイン特化なしでも汎用要約は有用"
      },
      {
        "id": "H4",
        "basis": "H1,H3",
        "refutation": "ユーザーが要約より原音声を常に好む",
        "content": "要約はポッドキャスト発見・選択を促進する"
      },
      {
        "id": "H5",
        "basis": "H2,H3",
        "refutation": "重要な議論のニュアンスが失われる",
        "content": "キーポイント抽出は全体要約より有用"
      },
      {
        "id": "H6",
        "basis": "H1,H2",
        "refutation": "タイムスタンプ精度が不十分",
        "content": "要約からの原音声該当箇所へのリンクは実現可能"
      }
    ]
  }
