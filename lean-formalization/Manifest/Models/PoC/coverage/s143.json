  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "船体構造はIMO(国際海事機関)の安全基準および船級協会の規格を満たさなければならない"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "設計変更の最終承認は主任設計技師が行う"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "船体の抵抗・推進性能はCFD(数値流体力学)シミュレーションで評価する"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "建造コストは鋼材使用量と溶接工数で大部分が決まる"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "燃費性能は船主の最優先要件である"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C3"
          ],
          "refutation": "CFDの解像度が不十分で乱流モデルが実験と乖離する場合"
        }
      },
      "content": "CFDシミュレーションの精度は模型試験と5%以内の誤差で一致する"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C4",
            "C5"
          ],
          "refutation": "新素材(FRP等)の採用で鋼材使用量とコストの関係が変わる場合"
        }
      },
      "content": "船体形状の最適化により鋼材使用量を削減しつつ燃費を改善できる"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C4"
          ],
          "refutation": "多目的最適化の探索空間が広すぎて実用的な計算時間内に収束しない場合"
        }
      },
      "content": "遺伝的アルゴリズムによる多目的最適化がパレート最適解を効率的に探索できる"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C5"
          ],
          "refutation": "代替モデルの近似誤差が大きく最適解が実際には劣解である場合"
        }
      },
      "content": "サロゲートモデルによりCFDの計算コストを1/100に削減できる"
    }
  ]
}
