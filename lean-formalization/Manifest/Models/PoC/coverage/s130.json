  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "翻訳の意味的等価性が最優先の品質基準"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "翻訳は原語の文体・ニュアンスをできるだけ保持する"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "字幕は1行あたり最大13文字（日本語）/ 42文字（英語）"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "字幕の表示時間は音声と同期し、最低1秒・最大7秒"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "品質評価は人間の主観評価（MOS）との相関0.8以上を目標"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C4"
          ],
          "refutation": "ストリーミング字幕でフレーム単位の同期が不要な場合"
        }
      },
      "content": "字幕の表示速度（文字/秒）が可読性の重要な指標"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "BLEUスコアが人間評価と十分に相関する場合"
        }
      },
      "content": "BERTScoreが字幕翻訳の意味的等価性の自動評価に適している"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C1",
            "C3"
          ],
          "refutation": "圧縮による情報損失が許容範囲内の場合"
        }
      },
      "content": "字幕特有の文圧縮による意味変容の検出が品質評価に不可欠"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C2",
            "C4"
          ],
          "refutation": "感情表現の評価が不要なドキュメンタリー等の場合"
        }
      },
      "content": "感情的ニュアンスの保持度を別指標で評価すべき"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C5",
            "H2"
          ],
          "refutation": "大規模並行コーパスが既に利用可能な場合"
        }
      },
      "content": "映画・ドラマの字幕並行コーパスの構築が評価モデルの精度向上に必要"
    },
    {
      "id": "H6",
      "source": {
        "llmInference": {
          "basis": [
            "H3",
            "H4"
          ],
          "refutation": "ジャンル間の品質基準が統一されている場合"
        }
      },
      "content": "ジャンル別（映画/アニメ/ニュース）の評価基準の差異を考慮すべき"
    }
  ]
