  "assumptions": {
    "C": [
      {
        "id": "C1",
        "source": "humanDecision",
        "content": "検索結果は法的助言ではなく参考情報であることを明示する"
      },
      {
        "id": "C2",
        "source": "humanDecision",
        "content": "非公開判例・係属中事件の情報は取り扱わない"
      },
      {
        "id": "C3",
        "source": "humanDecision",
        "content": "検索結果の最終的な法的判断は弁護士が行う"
      },
      {
        "id": "C4",
        "source": "humanDecision",
        "content": "関連判例は最新から時系列順に提示する"
      },
      {
        "id": "C5",
        "source": "humanDecision",
        "content": "判例の引用形式は裁判所の公式形式に準拠する"
      }
    ],
    "H": [
      {
        "id": "H1",
        "basis": "外部知識",
        "refutation": "判例DBの網羅性が不十分な法域が存在",
        "content": "主要判例データベースは公開判例を網羅している"
      },
      {
        "id": "H2",
        "basis": "C2,H1",
        "refutation": "法改正で過去判例の有効性判定が困難",
        "content": "判例の有効性（変更・破棄の有無）は追跡可能"
      },
      {
        "id": "H3",
        "basis": "H1,H2",
        "refutation": "法律用語の多義性でセマンティック検索が誤動作",
        "content": "自然言語クエリから法的争点を正確に抽出可能"
      },
      {
        "id": "H4",
        "basis": "C1,外部知識",
        "refutation": "類似度スコアが法的関連性と乖離",
        "content": "判例の類似度計算は法的論点ベースで実用的"
      },
      {
        "id": "H5",
        "basis": "H3,H4",
        "refutation": "専門分野ごとの判例構造の違いで汎化失敗",
        "content": "分野横断的な判例検索は単一分野検索より有用"
      },
      {
        "id": "H6",
        "basis": "H2,H3",
        "refutation": "判例の要旨自動抽出が重要論点を欠落",
        "content": "判例要旨の自動生成は弁護士の初期調査を効率化する"
      }
    ]
  }
}
