  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "噴火警報発令時には住民避難を最優先し、AIの予測が不確実でも安全側に判断する"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "避難指示の最終判断は自治体の防災担当者が行う。AIは支援情報の提供のみ"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "マグマの上昇は地震活動・地殻変動・火山ガス放出の3指標で捉えられる"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "気象庁の観測網データをリアルタイムで受信できる"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "GPSによる地殻変動データは1分間隔で取得する"
    },
    {
      "id": "C6",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q6",
          "date": "2026-03-26"
        }
      },
      "content": "過去の噴火データは気象庁のデータベースから取得可能"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C3"
          ],
          "refutation": "水蒸気爆発など前兆なしの噴火パターンが存在する場合"
        }
      },
      "content": "3指標の統合解析により噴火の数時間前に前兆を検出できる"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C4",
            "C5"
          ],
          "refutation": "通信障害や機器故障でデータ欠損が頻発する場合"
        }
      },
      "content": "リアルタイムデータの欠損率は5%以下に抑えられる"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C6"
          ],
          "refutation": "過去の噴火パターンが将来の噴火に適用できない場合"
        }
      },
      "content": "過去データに基づく統計モデルが噴火確率の推定に有用"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C4",
            "C5"
          ],
          "refutation": "センサー配置の最適化が不可能な地形条件がある場合"
        }
      },
      "content": "観測点の空間配置を最適化することで予測精度が向上する"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C6"
          ],
          "refutation": "深層学習モデルが物理モデルを超える精度を達成できない場合"
        }
      },
      "content": "深層学習による時系列解析が統計モデルより高精度な予測を実現する"
    }
  ]
