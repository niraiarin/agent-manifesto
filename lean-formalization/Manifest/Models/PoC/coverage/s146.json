  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "正当な批判・意見表明と炎上は区別し、表現の自由を侵害しない"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "個人を特定する情報の収集は行わない。投稿の匿名性を保持する"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "監視対象はクライアント企業に関連するキーワードのみに限定する"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "炎上の定義は投稿量の急増とネガティブ感情の組合せとする"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "検知から広報チームへの通知は15分以内を目標とする"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "ポジティブな話題の急増(バズ)と炎上を投稿量だけでは区別できない場合"
        }
      },
      "content": "投稿量の時系列異常検知とネガティブ感情比率の組合せで炎上を検知できる"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "深夜・休日に広報担当者が不在で15分以内の対応が困難な場合"
        }
      },
      "content": "炎上レベルに応じた段階的エスカレーション(自動通知→電話→緊急会議)が有効"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "皮肉・比喩表現が感情分析の精度を著しく低下させる場合"
        }
      },
      "content": "BERTベースの感情分析が日本語SNS投稿のネガティブ検出に有効"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "リツイート数の急増が炎上でなくポジティブなバイラルである場合"
        }
      },
      "content": "投稿のリツイート・引用リツイートの連鎖パターンが炎上拡散の予測に有用"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "画像・動画のOCR精度が低くテキスト抽出が不十分な場合"
        }
      },
      "content": "画像内テキストのOCR解析が文字のみの監視では見逃すコンテンツを補完する"
    },
    {
      "id": "H6",
      "source": {
        "llmInference": {
          "basis": [
            "C4",
            "C5"
          ],
          "refutation": "まとめサイトの炎上増幅効果が一時的なトレンドにすぎない場合"
        }
      },
      "content": "まとめサイトへの転載を検知することで炎上の二次拡散を早期に捕捉できる"
    }
  ]
}
