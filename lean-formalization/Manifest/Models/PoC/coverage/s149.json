  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "海洋の酸性化はCO2の溶解による炭酸系平衡の変化で生じる。この化学過程は十分に理解されている"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "pH測定はスペクトルpH法(m-cresol purple指示薬)を使用し、精度±0.001 pHを確保する"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "全炭酸(DIC)と全アルカリ度(TA)の同時測定により炭酸系パラメータを完全に決定する"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "認証標準物質(CRM)による定期較正を実施する"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "沿岸域と外洋の両方を対象とし、ブイ型自動観測と調査船観測を併用する"
    },
    {
      "id": "C6",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q6",
          "date": "2026-03-26"
        }
      },
      "content": "データはGOOS(全球海洋観測システム)の標準フォーマットで公開する"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "海洋環境でのセンサードリフトが較正間隔より速い場合"
        }
      },
      "content": "分光pH計のドリフト補正により無人ブイでも3ヶ月間の連続計測が可能"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "沿岸域の局所的変動が大きすぎて代表的な測点選定が困難な場合"
        }
      },
      "content": "衛星海面水温データとの統合により観測空白域のpHを推定できる"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C5",
            "C6"
          ],
          "refutation": "異なるプラットフォーム間のデータ品質の不均一性が統合を妨げる場合"
        }
      },
      "content": "ブイ・調査船・衛星データの統合により高解像度の酸性化マップを構築できる"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C1",
            "C5"
          ],
          "refutation": "気候モデルの不確実性が酸性化予測の信頼区間を実用的な範囲を超えて広げる場合"
        }
      },
      "content": "地球システムモデル(ESM)のダウンスケーリングにより地域スケールの酸性化予測が可能"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C1"
          ],
          "refutation": "種ごとの酸性化耐性の変異が大きく生態系レベルの影響予測が困難な場合"
        }
      },
      "content": "サンゴ礁の石灰化率低下と酸性化の進行度に定量的な関係がある"
    }
  ]
}
