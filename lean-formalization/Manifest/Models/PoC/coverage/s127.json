  "_monotonicity_violation": {
    "detected": true,
    "description": "「取引速度の異常検知ルール」(DetectionRule, ord=3) が「デバイスフィンガープリントの特徴量」(FeatureEngineering, ord=2) に依存するのは単調性を満たす。しかし、「不正パターンのグラフ分析」(RiskFramework, ord=4) が「GNNベースのアカウント関連性モデル」(ModelSelection, ord=1) に依存する形で設計されており、依存先(ord=1) < 依存元(ord=4) で単調性違反。H6由来のためLLMが自律修正。",
    "violating_edge": {
      "from": "s127_p10",
      "from_layer": "RiskFramework",
      "from_ord": 4,
      "to": "s127_p20",
      "to_layer": "ModelSelection",
      "to_ord": 1
    },
    "resolution": {
      "action": "promote",
      "detail": "H6由来（LLM推論のみ、C関与なし）。「GNNベースのアカウント関連性モデル」をModelSelection(ord=1)からRiskFramework(ord=4)に昇格。グラフ分析は不正パターンのリスク評価の一部であり、技術選択ではなくリスクフレームワークの構成要素として扱うのが適切。",
      "updated_assignment": {
        "proposition": "s127_p20",
        "layerName": "RiskFramework",
        "justification": [
          "H6",
          "C4"
        ]
      }
    },
    "post_resolution_violations": 0
  },
