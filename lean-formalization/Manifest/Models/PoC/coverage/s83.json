  "assumptions": {
    "C": [
      {
        "id": "C1",
        "source": "humanDecision",
        "content": "異常検知結果は医師の最終判断なしに患者に通知しない"
      },
      {
        "id": "C2",
        "source": "humanDecision",
        "content": "偽陰性率を1%未満に維持する（見逃し防止優先）"
      },
      {
        "id": "C3",
        "source": "humanDecision",
        "content": "異常値の定義は国際臨床ガイドラインに準拠する"
      },
      {
        "id": "C4",
        "source": "humanDecision",
        "content": "24時間以内に全検体の結果を返す"
      },
      {
        "id": "C5",
        "source": "humanDecision",
        "content": "個人の検査履歴は5年間保持し比較可能とする"
      },
      {
        "id": "C6",
        "source": "humanDecision",
        "content": "患者データの匿名化なしの二次利用を禁止する"
      }
    ],
    "H": [
      {
        "id": "H1",
        "basis": "C3,外部知識",
        "refutation": "ガイドラインが大幅改定された場合",
        "content": "基準値範囲は年齢・性別で十分に層別化されている"
      },
      {
        "id": "H2",
        "basis": "C2,外部知識",
        "refutation": "新規バイオマーカーの発見で既存指標が陳腐化",
        "content": "既存の血液検査項目で主要疾患の早期検出が可能"
      },
      {
        "id": "H3",
        "basis": "C4",
        "refutation": "検査機器の故障率が想定を超過",
        "content": "自動分析装置のスループットは処理要件を満たす"
      },
      {
        "id": "H4",
        "basis": "H1,H2",
        "refutation": "訓練データにバイアスが存在",
        "content": "過去の検査データで訓練した異常検知モデルは汎化する"
      },
      {
        "id": "H5",
        "basis": "C5,H3",
        "refutation": "データ形式の非互換が蓄積",
        "content": "時系列比較により個人の経年変化を検出可能"
      },
      {
        "id": "H6",
        "basis": "H2,H4",
        "refutation": "多変量解析の次元の呪いで精度劣化",
        "content": "複数項目の組合せ異常は単項目より検出感度が高い"
      },
      {
        "id": "H7",
        "basis": "H4,H6",
        "refutation": "実臨床でのモデル精度が検証環境を大幅に下回る",
        "content": "深層学習ベースの異常検知は従来統計手法を上回る"
      },
      {
        "id": "H8",
        "basis": "H5,H6",
        "refutation": "季節変動等の交絡因子で偽陽性が増大",
        "content": "経年変化と急性変化の区別は自動化可能"
      }
    ]
  }
}
