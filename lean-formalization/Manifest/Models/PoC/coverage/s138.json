  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "災害対策基本法に基づき、自治体は住民3日分の食料・水を備蓄する義務がある"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "備蓄品には消費期限があり、ローリングストック方式で定期入替を行う"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "備蓄品目はアレルギー対応・乳幼児用・要配慮者向けを含む多品目構成とする"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "備蓄倉庫は市内10箇所に分散配置し、各地域の人口比で配分する"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "年間備蓄予算の範囲内で最適な入替計画を立案する"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C2",
            "C4"
          ],
          "refutation": "備蓄倉庫の温度管理が不十分で消費期限が短縮される場合"
        }
      },
      "content": "消費期限の残存日数に基づく入替優先度の自動算出が可能"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "備蓄品の調達コストが急騰し予算制約が厳しくなる場合"
        }
      },
      "content": "一括調達と分散調達のコスト最適化により予算内で備蓄量を最大化できる"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C1",
            "C4"
          ],
          "refutation": "人口動態の急変（大規模開発等）により配分比が頻繁に変わる場合"
        }
      },
      "content": "地域別の人口・世帯構成の変化予測に基づき備蓄配分を動的に調整できる"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C1",
            "C2"
          ],
          "refutation": "過去の災害データが少なく統計的に有意な需要予測ができない場合"
        }
      },
      "content": "過去の災害時の備蓄消費パターンから品目別の需要予測モデルを構築できる"
    }
  ]
}
