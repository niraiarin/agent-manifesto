  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "信号機故障時は全方向赤点滅に切り替えるフェイルセーフ機構が必須"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "故障検知から現場対応までの目標時間は30分以内"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "LED信号機と従来型電球信号機の両方が対象"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "保守作業員の人数は固定。予防保守の優先順位付けが必要"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "信号制御器のログデータは過去5年分が蓄積されている"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C2",
            "C4"
          ],
          "refutation": "地方部では移動距離が長く30分以内の対応が物理的に不可能な場合"
        }
      },
      "content": "故障確率の高い信号機を事前に特定し巡回ルートに組み込むことで対応時間を短縮できる"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C5"
          ],
          "refutation": "旧型信号機のログフォーマットが統一されておらずデータ統合が困難な場合"
        }
      },
      "content": "LED信号機と電球型で異なる故障パターンを別モデルで学習すべき"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "過去データに含まれない新型故障モードが出現する場合"
        }
      },
      "content": "制御器ログの電圧変動パターンから故障の72時間前予測が可能"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C5"
          ],
          "refutation": "気象データと故障の相関が地域ごとに大きく異なる場合"
        }
      },
      "content": "気温・湿度・日照時間の気象データと故障率に有意な相関がある"
    }
