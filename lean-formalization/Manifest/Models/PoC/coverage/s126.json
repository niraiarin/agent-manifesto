  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "PM2.5の環境基準値（年平均15μg/m³、日平均35μg/m³）を超過した場合に警報を発する"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "AQI（大気質指数）の計算方法はEPA基準に準拠する"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "既存の公設モニタリングステーションのデータを活用する"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "低コストセンサーで補完的にメッシュ密度を上げる"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "予測は6時間先まで、1時間刻みで提供する"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C4"
          ],
          "refutation": "低コストセンサーの精度がキャリブレーション不能なほど低い場合"
        }
      },
      "content": "低コストセンサーは公設局データでキャリブレーション可能"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "気象データの精度が予測に不十分な場合"
        }
      },
      "content": "気象予報データと組み合わせたLSTMモデルが6時間予測に有効"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C4"
          ],
          "refutation": "交通量データが利用不可な場合"
        }
      },
      "content": "交通量データが局所的なPM2.5予測の精度を向上させる"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "H1"
          ],
          "refutation": "センサー配置が均一で空間補間が不要な場合"
        }
      },
      "content": "クリギング法によるセンサー間の空間補間が有効"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C1",
            "H2"
          ],
          "refutation": "固定閾値で十分な運用精度が得られる場合"
        }
      },
      "content": "季節・曜日による基準値の動的調整が誤報を減少させる"
    },
    {
      "id": "H6",
      "source": {
        "llmInference": {
          "basis": [
            "C1",
            "C5"
          ],
          "refutation": "利用者が全員同じ情報粒度を求める場合"
        }
      },
      "content": "利用者属性（喘息患者等）に応じた個別警報閾値が有効"
    }
  ]
