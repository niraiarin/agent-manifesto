  "assumptions": {
    "C": [
      {
        "id": "C1",
        "source": "humanDecision",
        "content": "地絡・漏電リスクのあるパネルは即時停止・隔離する"
      },
      {
        "id": "C2",
        "source": "humanDecision",
        "content": "定期点検は電気事業法の頻度要件を遵守する"
      },
      {
        "id": "C3",
        "source": "humanDecision",
        "content": "発電量データは30分単位で20年間保存する"
      },
      {
        "id": "C4",
        "source": "humanDecision",
        "content": "劣化診断結果に基づく交換判断は人間が行う"
      },
      {
        "id": "C5",
        "source": "humanDecision",
        "content": "パネル交換の費用対効果は残存FIT期間で評価する"
      }
    ],
    "H": [
      {
        "id": "H1",
        "basis": "外部知識",
        "refutation": "日射量データの空間解像度が不足",
        "content": "気象庁の日射量データは発電量推定に十分な精度"
      },
      {
        "id": "H2",
        "basis": "C2,H1",
        "refutation": "パネルメーカーごとの劣化曲線データが非公開",
        "content": "パネルのI-V特性測定データから劣化率を定量化可能"
      },
      {
        "id": "H3",
        "basis": "C4,H2",
        "refutation": "ホットスポット検出の赤外線カメラ精度が不十分",
        "content": "赤外線サーモグラフィによるホットスポット検出は実用的"
      },
      {
        "id": "H4",
        "basis": "H1,H2",
        "refutation": "PID劣化等の突発的劣化モードが予測不能",
        "content": "経年劣化の進行速度は過去データから予測可能"
      },
      {
        "id": "H5",
        "basis": "外部知識",
        "refutation": "ストリング単位のモニタリング装置未設置",
        "content": "パネル単位の発電量モニタリングは技術的に可能"
      },
      {
        "id": "H6",
        "basis": "H2,H3",
        "refutation": "汚れ・影の影響と劣化の区別が困難",
        "content": "劣化要因の分離（汚れ/影/経年劣化/故障）は自動化可能"
      },
      {
        "id": "H7",
        "basis": "H4,H6",
        "refutation": "保守コストモデルの精度が不十分",
        "content": "最適なパネル交換タイミングはLCOE最小化で決定可能"
      }
    ]
  }
}
