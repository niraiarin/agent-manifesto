  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "雪崩警報は人命に直結するため、偽陰性（見逃し）を最小化しなければならない"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "最終的な避難指示の発令は自治体の防災担当者が行う"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "積雪の層構造（弱層の存在）が雪崩発生の主要因である"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "観測データは気象庁AMeDASと現地積雪観測所から取得する"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "複数センサーのデータを統合して危険度を評価したい"
    },
    {
      "id": "C6",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q6",
          "date": "2026-03-26"
        }
      },
      "content": "スキー場運営者にもリアルタイムで危険度情報を提供したい"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C3"
          ],
          "refutation": "湿雪雪崩など弱層以外の要因が支配的な地域では適用が限定的"
        }
      },
      "content": "弱層の形成は気温の日較差と降雪パターンから推定可能"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "AMeDASの観測点密度が低い山岳地域では空間補間の精度が不十分"
        }
      },
      "content": "AMeDASデータは10分間隔で取得可能であり、リアルタイム性は十分"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "センサー間のデータ形式が統一されていない場合、前処理コストが大きい"
        }
      },
      "content": "積雪深・気温・風速・降水量の4変数で危険度の80%を説明可能"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C5"
          ],
          "refutation": "過去の雪崩データが少ない地域では統計的妥当性が低い"
        }
      },
      "content": "過去30年分の雪崩発生データとの照合で検証精度を確保できる"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C6"
          ],
          "refutation": "スキー場ごとに地形が大きく異なり汎用モデルが適用困難な場合"
        }
      },
      "content": "スキー場ごとの地形データを組み込むことで予測精度が向上する"
    }
  ]
}
