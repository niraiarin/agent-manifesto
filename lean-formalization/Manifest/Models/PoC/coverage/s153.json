  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "海上衝突予防規則（COLREG 1972）の全条項を遵守する。特に規則13-17（追越し・行会い・横切り・避航船・保持船）"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "船舶の旋回性能（旋回径・キック・アドバンス）は操縦性能基準に基づく物理的限界がある"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "停船距離は速力と積載量に依存し、即時停止は不可能である"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "レーダー（X帯・S帯）、AIS、光学カメラの3系統のセンサーを統合して使用する"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "最終的な操船判断は船長が行う。AIは回避案を提示し船長が承認する"
    },
    {
      "id": "C6",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q6",
          "date": "2026-03-26"
        }
      },
      "content": "沿岸航行と外洋航行で回避パラメータ（安全距離・回避開始タイミング）を変える"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "単一センサーで十分な検知精度が得られる場合"
        }
      },
      "content": "センサーフュージョンではカルマンフィルタによる他船追跡が有効。各センサーの特性を補完する"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C1",
            "C2"
          ],
          "refutation": "COLREGの解釈が全状況で一意に定まる場合"
        }
      },
      "content": "COLREG規則の適用が曖昧な状況（交差する義務等）では最も保守的な解釈を採用すべき"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C2",
            "C3"
          ],
          "refutation": "全船舶の操縦性能が均一である場合"
        }
      },
      "content": "回避行動の開始タイミングは船舶の操縦性能（旋回径・停船距離）に基づいて動的に決定すべき"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "完全自律航行が法的に認められた場合"
        }
      },
      "content": "自律度はIMOの自律船ガイドライン（MASS degree 2: 遠隔操作・船上判断）に準拠すべき"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C6",
            "C4"
          ],
          "refutation": "航路に関わらず一律のパラメータで安全が確保できる場合"
        }
      },
      "content": "狭水道・輻輳海域では安全距離を通常の2倍に設定し、回避開始を早める"
    },
    {
      "id": "H6",
      "source": {
        "llmInference": {
          "basis": [
            "C6"
          ],
          "refutation": "天候がセンサー性能に影響しない場合"
        }
      },
      "content": "視界制限状態（濃霧等）ではレーダー依存度を上げ、安全マージンを拡大する"
    }
  ]
}
