  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "エレベーターの安全性は建築基準法施行令129条に定められた基準を満たさなければならない"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "故障予測の結果に関わらず、法定点検は省略できない"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "過去10年分の保守記録と故障履歴がデータベースに蓄積されている"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "振動センサーとモーター電流センサーのデータをリアルタイムで取得する"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "予測に基づく予防保守で保守コストの削減を目指す"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C3"
          ],
          "refutation": "保守記録のデータ品質（記録漏れ・分類の不統一）が低い場合"
        }
      },
      "content": "ワイブル分布で主要部品の故障時期を統計的に推定可能"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "振動パターンが故障モードと1対1に対応しない場合"
        }
      },
      "content": "振動の周波数スペクトル変化がベアリング劣化の早期指標になる"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C4"
          ],
          "refutation": "異なるメーカー・機種間でモデルの転用ができない場合"
        }
      },
      "content": "LSTMで時系列センサーデータから故障までの残存寿命を予測可能"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "予防保守の頻度増加がコスト削減効果を相殺する場合"
        }
      },
      "content": "故障前の予防交換により緊急停止件数を50%削減可能"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C5"
          ],
          "refutation": "部品の在庫管理コストが予測精度に見合わない場合"
        }
      },
      "content": "故障予測に基づく部品の事前発注で在庫最適化が可能"
    }
  ]
}
