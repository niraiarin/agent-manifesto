{
  "namespace": "AirportBaggage",
  "assumptions": {
    "C": [
      {
        "id": "C1",
        "source": "humanDecision",
        "content": "手荷物の紛失率を0.1%以下に維持する"
      },
      {
        "id": "C2",
        "source": "humanDecision",
        "content": "乗客のプライバシーを保護し、手荷物画像を追跡以外に使わない"
      },
      {
        "id": "C3",
        "source": "humanDecision",
        "content": "空港職員が最終的な手荷物再ルーティングを判断する"
      },
      {
        "id": "C4",
        "source": "humanDecision",
        "content": "IATA規格に準拠したタグ読み取りを行う"
      },
      {
        "id": "C5",
        "source": "humanDecision",
        "content": "リアルタイム追跡で遅延荷物を5分以内に検知する"
      },
      {
        "id": "C6",
        "source": "humanDecision",
        "content": "他空港システムとのデータ連携は標準APIで行う"
      }
    ],
    "H": [
      {
        "id": "H1",
        "basis": "C4",
        "refutation": "IATA以外の独自規格が主流になった場合",
        "content": "RFIDタグ読取精度は99.5%以上を前提とする"
      },
      {
        "id": "H2",
        "basis": "C5,C6",
        "refutation": "ネットワーク遅延が恒常的に10秒以上の場合",
        "content": "空港間データ連携の遅延は3秒以内"
      },
      {
        "id": "H3",
        "basis": "C1",
        "refutation": "AI判断が人間を上回ることが実証された場合",
        "content": "再ルーティング提案はAIが行い最終判断は人間"
      },
      {
        "id": "H4",
        "basis": "C5",
        "refutation": "センサー技術の根本的変化",
        "content": "コンベア上の荷物位置はカメラ+RFIDの融合で特定"
      },
      {
        "id": "H5",
        "basis": "H2",
        "refutation": "完全オフライン運用が可能になった場合",
        "content": "クラウド接続断時はローカルキャッシュで30分稼働可能"
      }
    ]
  },
