  "assumptions": {
    "C": [
      {
        "id": "C1",
        "source": "humanDecision",
        "content": "放流操作は人間の最終承認なしに実行しない"
      },
      {
        "id": "C2",
        "source": "humanDecision",
        "content": "設計洪水流量を超える場合は非常用洪水吐きを開放する"
      },
      {
        "id": "C3",
        "source": "humanDecision",
        "content": "下流域住民への放流通知は操作の30分前に行う"
      },
      {
        "id": "C4",
        "source": "humanDecision",
        "content": "利水・治水の優先順位は季節と水位で決定する"
      },
      {
        "id": "C5",
        "source": "humanDecision",
        "content": "堆砂量の年間計測を実施し貯水容量を更新する"
      },
      {
        "id": "C6",
        "source": "humanDecision",
        "content": "環境放流量の最低基準を下回らない"
      }
    ],
    "H": [
      {
        "id": "H1",
        "basis": "外部知識",
        "refutation": "気象庁のデータ配信が長期停止",
        "content": "気象レーダーと雨量計データはリアルタイムで取得可能"
      },
      {
        "id": "H2",
        "basis": "H1,外部知識",
        "refutation": "流域の土地利用変化で流出係数が大幅変動",
        "content": "流域の降雨-流出モデルは過去データで校正済み"
      },
      {
        "id": "H3",
        "basis": "C4,H1",
        "refutation": "ゲート設備の老朽化で応答遅延",
        "content": "ゲート操作の応答時間は制御要件を満たす"
      },
      {
        "id": "H4",
        "basis": "H1,H2",
        "refutation": "ゲリラ豪雨の頻度増加で予測精度が低下",
        "content": "6時間先までの流入量予測は実用精度を持つ"
      },
      {
        "id": "H5",
        "basis": "外部知識",
        "refutation": "水位計の測定誤差が許容範囲を超過",
        "content": "貯水位センサーの精度は管理基準を満たす"
      },
      {
        "id": "H6",
        "basis": "C5,H2",
        "refutation": "異常堆砂で有効貯水量が急減",
        "content": "堆砂進行は線形近似で中期予測可能"
      },
      {
        "id": "H7",
        "basis": "H4,H6",
        "refutation": "複数ダムの連携最適化が局所最適に陥る",
        "content": "上下流ダムの連携放流最適化は単独運用より効率的"
      },
      {
        "id": "H8",
        "basis": "H4,H7",
        "refutation": "気候変動で過去データの代表性が失われる",
        "content": "長期の貯水池運用計画はシミュレーションで最適化可能"
      }
    ]
  }
}
