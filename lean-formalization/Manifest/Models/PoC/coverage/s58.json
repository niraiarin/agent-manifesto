        "content": "オークション終了30秒前の自動入札を許可する"
      },
      {
        "id": "C6",
        "source": "humanDecision",
        "content": "過去の落札データを学習に使用する"
      }
    ],
    "H": [
      {
        "id": "H1",
        "basis": "C6",
        "refutation": "オークション形式が根本的に変化した場合",
        "content": "過去の落札価格分布は将来の予測に有効"
      },
      {
        "id": "H2",
        "basis": "C5",
        "refutation": "オークション規約で自動入札が禁止された場合",
        "content": "スナイピング戦略は競合入札を抑制できる"
      },
      {
        "id": "H3",
        "basis": "C1,C4",
        "refutation": "予算制約が不要になった場合",
        "content": "複数オークションの並行入札で期待値を最大化できる"
      },
      {
        "id": "H4",
        "basis": "C6",
        "refutation": "出品者の行動パターンが急変した場合",
        "content": "出品者の価格設定パターンは統計的に安定"
      },
      {
        "id": "H5",
        "basis": "C3",
        "refutation": "キャンセルポリシーが緩和された場合",
        "content": "落札リスクを考慮した保守的な入札が安全"
      }
    ]
  },
