  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "来園者の顔画像は保存せず、統計的な人数カウントと動線分析のみ行う"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "カメラの設置場所と目的を園内に掲示し、来園者に告知する"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "動物の展示エリアの混雑が動物にストレスを与えるため、滞留人数に上限を設ける"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "混雑時はスタッフを動的に再配置して安全を確保する"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "既設の防犯カメラ映像を流用し、追加設備投資は最小限にする"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C3"
          ],
          "refutation": "動物の種類によってストレス反応の閾値が大きく異なる場合"
        }
      },
      "content": "滞留人数が一定値を超えると動物の行動パターンにストレス反応が現れる"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "スタッフの再配置が来園者の不満を招く場合"
        }
      },
      "content": "リアルタイムの混雑度マップにより最適なスタッフ配置を算出できる"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "既設カメラの画角・解像度が人数カウントに不十分な場合"
        }
      },
      "content": "既設防犯カメラの映像からYOLOv8による人物検出で十分な精度の人数カウントが可能"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C4"
          ],
          "refutation": "天候・イベントなど外部要因の影響が大きく予測困難な場合"
        }
      },
      "content": "曜日・時間帯・天候に基づく混雑予測モデルが翌日の来園者数を予測できる"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "動線データの解像度が粗く展示ごとの滞在時間を正確に計測できない場合"
        }
      },
      "content": "来園者の動線パターンから人気展示と回遊経路を特定し、展示レイアウト改善に活用できる"
    }
  ]
}
