  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "地雷探知の偽陰性率はゼロでなければならない。人間の安全が最優先"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "ロボットが除去を行う前に、人間のオペレーターが最終確認を行う"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "オタワ条約および国際人道法の規定に準拠する"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "探知・除去作業は定められた安全距離を確保した上で実施する"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "通信途絶時はロボットを即座に停止させる（フェイルセーフ）"
    },
    {
      "id": "C6",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q6",
          "date": "2026-03-26"
        }
      },
      "content": "地雷原の地形データは事前に衛星・ドローンで取得済み"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C3"
          ],
          "refutation": "国際法の改正により除去手順の要件が変更された場合"
        }
      },
      "content": "除去作業の記録・報告義務は条約上の法的要件として遵守すべき"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C4",
            "C6"
          ],
          "refutation": "事前地形データの精度が現場実態と大きく乖離する場合"
        }
      },
      "content": "事前地形データに基づくルートプランニングにより安全距離を最適化できる"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C1",
            "C6"
          ],
          "refutation": "金属探知以外のセンサー（GPR等）が主要探知手段になる場合"
        }
      },
      "content": "マルチセンサー融合（金属探知+GPR+赤外線）が単一センサーより検出率を向上させる"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C4",
            "C5"
          ],
          "refutation": "ロボットの自律制御が人間の遠隔操作より安全な場合"
        }
      },
      "content": "遠隔操作モードと自律モードの切り替えを動的に行うことで柔軟性を確保できる"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C6"
          ],
          "refutation": "LiDARが砂漠環境で十分な精度を出せない場合"
        }
      },
      "content": "リアルタイムLiDARマッピングが事前データの補正に有効"
    },
    {
      "id": "H6",
      "source": {
        "llmInference": {
          "basis": [
            "C1",
            "H3"
          ],
          "refutation": "強化学習がシミュレーション環境と実環境の差異で失敗する場合"
        }
      },
      "content": "強化学習により探知パターンを地雷タイプごとに最適化できる"
    },
    {
      "id": "H7",
      "source": {
        "llmInference": {
          "basis": [
            "H4",
            "H5"
          ],
          "refutation": "群制御の通信オーバーヘッドが許容範囲を超える場合"
        }
      },
      "content": "複数ロボットの協調作業（スウォーム）により除去効率が線形以上に向上する"
    }
  ]
}
