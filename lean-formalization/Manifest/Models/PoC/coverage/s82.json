  "assumptions": {
    "C": [
      {
        "id": "C1",
        "source": "humanDecision",
        "content": "ユーザーの顔・体型データは端末内処理のみで外部送信しない"
      },
      {
        "id": "C2",
        "source": "humanDecision",
        "content": "価格表示は景品表示法に準拠し誤認を招かない"
      },
      {
        "id": "C3",
        "source": "humanDecision",
        "content": "AR表示の最終的なON/OFF権限はユーザーにある"
      },
      {
        "id": "C4",
        "source": "humanDecision",
        "content": "推薦商品にはスポンサー表示を明示する"
      },
      {
        "id": "C5",
        "source": "humanDecision",
        "content": "未成年ユーザーへの年齢制限商品表示を禁止する"
      }
    ],
    "H": [
      {
        "id": "H1",
        "basis": "外部知識",
        "refutation": "ARデバイスの普及率が想定以下",
        "content": "ARデバイスのカメラ精度は商品認識に十分である"
      },
      {
        "id": "H2",
        "basis": "外部知識",
        "refutation": "5G/Wi-Fiが店舗内で不安定",
        "content": "店舗内ネットワーク帯域はAR描画に十分"
      },
      {
        "id": "H3",
        "basis": "C3,H1",
        "refutation": "ユーザーがAR表示を煩わしく感じる",
        "content": "AR商品オーバーレイは購買意思決定を促進する"
      },
      {
        "id": "H4",
        "basis": "C4,H2",
        "refutation": "推薦精度が低くユーザー離脱",
        "content": "購買履歴ベースの推薦は店頭でも有効"
      },
      {
        "id": "H5",
        "basis": "外部知識",
        "refutation": "端末処理能力の不足でリアルタイム不可",
        "content": "端末のGPU性能はリアルタイムAR描画に十分"
      },
      {
        "id": "H6",
        "basis": "H1,H3",
        "refutation": "バーチャル試着の精度不足で返品率増加",
        "content": "バーチャル試着は返品率を低減する"
      },
      {
        "id": "H7",
        "basis": "H3,H4",
        "refutation": "情報過多でユーザーが選択疲労",
        "content": "関連商品のAR表示はクロスセルを促進する"
      }
    ]
  }
}
