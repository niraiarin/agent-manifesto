  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "歩行者との接触事故はゼロでなければならない。衝突回避は最優先"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "ドライバーはいつでも手動介入できなければならない"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "自動駐車機能は国土交通省の型式認証を取得する必要がある"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "駐車場の白線・区画情報は施設管理者から提供される"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "駐車経路は最短距離よりも安全マージンを優先して計画する"
    },
    {
      "id": "C6",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q6",
          "date": "2026-03-26"
        }
      },
      "content": "超音波センサーとカメラの両方を搭載する予定"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C3"
          ],
          "refutation": "型式認証の要件が改定された場合、準拠基準が変わる"
        }
      },
      "content": "UN-R79（自動操舵に関する国連規則）への準拠が型式認証の前提条件"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "白線が劣化・消失している駐車場では区画認識精度が低下する"
        }
      },
      "content": "白線認識にはセマンティックセグメンテーションが有効"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "狭小区画では安全マージンの確保と駐車可能性がトレードオフになる"
        }
      },
      "content": "RRTアルゴリズムで安全マージンを制約として経路計画可能"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C4",
            "C5"
          ],
          "refutation": "動的障害物（歩行者・他車両）が多い場合、静的経路計画では不十分"
        }
      },
      "content": "静的環境（駐車場）ではオフライン経路計画が効率的"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C6"
          ],
          "refutation": "雨天・夜間でカメラ性能が大幅に低下する場合"
        }
      },
      "content": "超音波センサーとカメラの冗長構成で悪天候時にも検知精度を維持可能"
    },
    {
      "id": "H6",
      "source": {
        "llmInference": {
          "basis": [
            "C1",
            "C6"
          ],
          "refutation": "LiDARの価格低下により超音波センサーより優位になる場合"
        }
      },
      "content": "近距離（5m以内）の障害物検知では超音波センサーがカメラより高精度"
    }
  ]
}
