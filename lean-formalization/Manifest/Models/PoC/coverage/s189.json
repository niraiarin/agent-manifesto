  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "サンゴの白化は海水温上昇が主要因であり、1度の上昇で白化リスクが急増する"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "予測結果は環境省・地方自治体の保全活動の判断材料に使用する"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "NOAA衛星のSST（海面水温）データを主要入力として使用する"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "現地ダイバーによる定点観測データを地上検証（ground truth）に使用する"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "予測対象は日本近海のサンゴ礁域（沖縄・奄美・小笠原）"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C4"
          ],
          "refutation": "衛星SSTと水中温度の乖離が無視できないほど大きい場合"
        }
      },
      "content": "衛星SSTと水中温度計のキャリブレーションにより精度を担保できる"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C1",
            "C2"
          ],
          "refutation": "海水温以外のストレス要因（酸性化等）が支配的な場合"
        }
      },
      "content": "Degree Heating Weeks (DHW)が白化リスクの最良の予測指標"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C3"
          ],
          "refutation": "GCMの空間解像度がサンゴ礁スケールに不十分な場合"
        }
      },
      "content": "全球気候モデル（GCM）のダウンスケーリングにより地域レベルの予測が可能"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "種ごとの耐熱性の差異がモデルの汎用性を損なう場合"
        }
      },
      "content": "サンゴの種組成データを組み込むことで白化感受性の差異を反映できる"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C5",
            "H3"
          ],
          "refutation": "黒潮の蛇行パターンが予測不能で水温予測を撹乱する場合"
        }
      },
      "content": "海流モデル（黒潮の影響）の統合により日本近海固有の予測精度が向上する"
    },
    {
      "id": "H6",
      "source": {
        "llmInference": {
          "basis": [
            "H2",
            "H4"
          ],
          "refutation": "白化からの回復メカニズムが種・環境で大きく異なる場合"
        }
      },
      "content": "白化後の回復過程をモデルに組み込むことで長期的な保全戦略の評価が可能"
    }
  ]
}
