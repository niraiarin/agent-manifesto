  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "患者の安全が最優先。副作用リスクの見逃しは許容されない"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "医薬品医療機器等法に基づく副作用報告義務を遵守する"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "GVP省令に基づく安全管理体制の下で運用する"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "添付文書の薬理作用情報と臨床試験データを基礎データとして使用する"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "副作用アラートは処方医に即時通知し、最終判断は医師が行う"
    },
    {
      "id": "C6",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q6",
          "date": "2026-03-26"
        }
      },
      "content": "多剤併用患者の薬物相互作用を重点的に監視する"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "添付文書の記載が不完全で、実臨床データとの乖離が大きい場合"
        }
      },
      "content": "薬理作用の分子メカニズムから副作用経路を推論できる"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "処方時チェックの負荷が高すぎて医師がアラート疲れを起こす場合"
        }
      },
      "content": "処方オーダー時のリアルタイムチェックが最も効果的な介入タイミング"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C4",
            "C6"
          ],
          "refutation": "薬物相互作用のデータベースが網羅的でない場合"
        }
      },
      "content": "グラフニューラルネットワークで分子構造から相互作用を予測できる"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "電子カルテの自然言語記録の構造化が困難な場合"
        }
      },
      "content": "電子カルテの自然言語処理により未報告の副作用シグナルを検出できる"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C6",
            "H3"
          ],
          "refutation": "遺伝子多型データの取得コストが臨床利用に見合わない場合"
        }
      },
      "content": "薬物代謝酵素の遺伝子多型が個人差の主要因である"
    },
    {
      "id": "H6",
      "source": {
        "llmInference": {
          "basis": [
            "C4",
            "H4"
          ],
          "refutation": "マイクロバイオームの影響が薬物動態に与える効果が小さい場合"
        }
      },
      "content": "腸内細菌叢が経口薬の代謝に影響し副作用リスクを変動させる"
    }
  ]
