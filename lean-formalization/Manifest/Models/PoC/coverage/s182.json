  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "群衆密度が危険水準を超えた場合、即座にアラートを発する"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "避難経路の確保と誘導判断は人間のスタッフが最終決定する"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "消防法に基づく最大収容人数を超えないよう管理する"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "監視カメラとLiDARセンサーを併用して群衆密度を計測する"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "来場者数の予測には過去5年分の実績データを使用する"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C1",
            "C3"
          ],
          "refutation": "会場が屋内で風の影響を受けない場合"
        }
      },
      "content": "風向きの変化により群衆の移動パターンが急変するため、気象データとの連携が必要"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "LiDARが夜間の花火煙で計測精度が低下する場合"
        }
      },
      "content": "カメラとLiDARのセンサーフュージョンにより夜間でも高精度な密度推定が可能"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C4",
            "C5"
          ],
          "refutation": "会場レイアウトが毎年大幅に変更される場合"
        }
      },
      "content": "過去の動線データから渋滞ポイントを事前予測し、スタッフ配置を最適化できる"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C5",
            "H1"
          ],
          "refutation": "天候急変時の来場者行動が過去パターンと乖離する場合"
        }
      },
      "content": "時系列モデルによるリアルタイム来場者数予測の精度が80%以上に達する"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "H2",
            "H3"
          ],
          "refutation": "花火終了後の一斉退場パターンが予測不能な場合"
        }
      },
      "content": "退場時の群衆流を分散させるための段階的退場誘導アルゴリズムが有効"
    }
  ]
}
