  "assumptions": {
    "C": [
      {
        "id": "C1",
        "source": "humanDecision",
        "content": "農薬散布量は法定上限を超えてはならない"
      },
      {
        "id": "C2",
        "source": "humanDecision",
        "content": "食品安全基準の残留農薬値を遵守する"
      },
      {
        "id": "C3",
        "source": "humanDecision",
        "content": "散布判断の最終権限は農家にある"
      },
      {
        "id": "C4",
        "source": "humanDecision",
        "content": "予測結果は72時間以内の精度を保証範囲とする"
      },
      {
        "id": "C5",
        "source": "humanDecision",
        "content": "有機農法圃場では化学農薬の提案を禁止する"
      }
    ],
    "H": [
      {
        "id": "H1",
        "basis": "C4",
        "refutation": "気象データAPIが長期停止した場合",
        "content": "気象データは外部APIから安定的に取得できる"
      },
      {
        "id": "H2",
        "basis": "C4,外部知識",
        "refutation": "新種害虫の侵入で既存モデルが無効化",
        "content": "害虫の発生パターンは過去データから予測可能"
      },
      {
        "id": "H3",
        "basis": "C3",
        "refutation": "農家が閾値設定を放棄した場合",
        "content": "散布閾値は農家が作物ごとに適切に設定する"
      },
      {
        "id": "H4",
        "basis": "H1,H2",
        "refutation": "モデル精度が50%以下に低下",
        "content": "機械学習モデルの予測精度は実用水準を維持する"
      },
      {
        "id": "H5",
        "basis": "外部知識",
        "refutation": "土壌センサーの故障率が30%超過",
        "content": "土壌湿度データはセンサーから取得可能"
      },
      {
        "id": "H6",
        "basis": "C3,H4",
        "refutation": "農家が予測を完全無視する運用",
        "content": "予測結果に基づく散布計画は農家の意思決定を支援する"
      },
      {
        "id": "H7",
        "basis": "H2,H5",
        "refutation": "気候変動で過去パターンが完全崩壊",
        "content": "季節性パターンは害虫発生の主要予測因子である"
      }
    ]
  }
}
