  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "視覚障害者が文書にアクセスする権利は法的に保障されており、翻訳精度の下限を設けなければならない"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "翻訳結果の最終確認は点字校正者が行う。AIは下訳を提供するのみ"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "日本語点字は日本点字委員会の表記法に準拠する"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "リアルタイム翻訳と高精度バッチ翻訳の両モードを提供したい"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "点字ディスプレイとエンボッサーの両方に出力対応したい"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C3"
          ],
          "refutation": "外国語点字も対象とする場合、各言語固有の規則が必要"
        }
      },
      "content": "分かち書き規則はルールベースで高精度に実装可能"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "リアルタイム処理の遅延が許容範囲を超える場合"
        }
      },
      "content": "リアルタイムモードではルールベース、バッチモードではニューラル翻訳を使い分けるのが効率的"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C4"
          ],
          "refutation": "数式・化学式などの特殊記号が多い文書では専用パーサーが必要"
        }
      },
      "content": "一般的な文書では形態素解析と点字変換規則の組み合わせで90%以上の精度が達成可能"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "点字ディスプレイの仕様が機種ごとに大きく異なる場合"
        }
      },
      "content": "BRFフォーマットが点字ディスプレイの標準出力形式として最適"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C1",
            "C5"
          ],
          "refutation": "ユーザーが触読に慣れておらず別の出力形式を好む場合"
        }
      },
      "content": "エンボッサー出力では用紙サイズに応じた自動レイアウト調整が必要"
