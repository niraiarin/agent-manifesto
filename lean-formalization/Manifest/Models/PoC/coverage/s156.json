  "assumptions": [
    {
      "id": "C1",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q1",
          "date": "2026-03-26"
        }
      },
      "content": "運転手の連続運転時間は4時間以内、1日の拘束時間は13時間以内（労基法・改善基準告示）"
    },
    {
      "id": "C2",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q2",
          "date": "2026-03-26"
        }
      },
      "content": "路線認可されたルート・停留所は変更不可。ダイヤのみ最適化対象"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "ICカードの乗降データ（OD データ）を需要分析に使用する"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "保有車両数は30台で固定。車両配置を最適化する"
    },
    {
      "id": "C5",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q5",
          "date": "2026-03-26"
        }
      },
      "content": "バスロケーションシステムでリアルタイム位置を把握し、遅延を乗客に通知する"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C3"
          ],
          "refutation": "ICカード以外の乗車手段（現金）の利用者が多数を占める場合"
        }
      },
      "content": "ICカードデータに携帯電話の人流データを加えることで潜在需要を推定できる"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C1"
          ],
          "refutation": "需要が時間帯・曜日でほぼ均一な場合"
        }
      },
      "content": "朝夕ラッシュと日中の需要差が大きく、変動ダイヤ（時間帯別運行間隔）が有効"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "全路線が独立で車両共有が不要な場合"
        }
      },
      "content": "複数路線間での車両共有（インターライニング）により車両稼働率を向上できる"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C5"
          ],
          "refutation": "遅延がほとんど発生しない場合"
        }
      },
      "content": "連鎖遅延を防ぐため、遅延バスの後続便を増発する動的制御が有効"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C5",
            "C3"
          ],
          "refutation": "乗客がリアルタイム情報に反応して行動を変えない場合"
        }
      },
      "content": "遅延情報と代替経路の提示により乗客の分散が促進される"
    }
  ]
}
