          "date": "2026-03-26"
        }
      },
      "content": "標準試料との比較による校正を毎回実施する"
    },
    {
      "id": "C3",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q3",
          "date": "2026-03-26"
        }
      },
      "content": "ポリフェノール・テルペン・アルカロイドが主要分析対象"
    },
    {
      "id": "C4",
      "source": {
        "humanDecision": {
          "phase": 1,
          "question": "Q4",
          "date": "2026-03-26"
        }
      },
      "content": "近赤外分光法(NIR)による非破壊分析を一次スクリーニングに使用する"
    },
    {
      "id": "H1",
      "source": {
        "llmInference": {
          "basis": [
            "C3"
          ],
          "refutation": "未知の二次代謝産物が主要成分と干渉する場合"
        }
      },
      "content": "主要3成分群の定量で植物の機能性評価の80%をカバーできる"
    },
    {
      "id": "H2",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "NIRの波長分解能が不十分で類似成分の識別ができない場合"
        }
      },
      "content": "NIRスペクトルからPLS回帰で主要成分を同時定量できる"
    },
    {
      "id": "H3",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C4"
          ],
          "refutation": "水分含量の変動がNIR測定に大きな影響を与える場合"
        }
      },
      "content": "前処理(乾燥・粉砕)の標準化によりNIR測定の再現性が向上する"
    },
    {
      "id": "H4",
      "source": {
        "llmInference": {
          "basis": [
            "C3",
            "C4"
          ],
          "refutation": "品種間の化学的多様性が大きすぎてモデルの汎化が困難な場合"
        }
      },
      "content": "深層学習によるスペクトル解析がPLS回帰より高い予測精度を達成する"
    },
    {
      "id": "H5",
      "source": {
        "llmInference": {
          "basis": [
            "C4"
          ],
          "refutation": "サンプル前処理のばらつきが転移学習の精度を低下させる場合"
        }
      },
      "content": "異なる植物種間での転移学習が少量サンプルでの予測を可能にする"
    }
  ]
