    "scenario_id": 331,
    "project": "原子力安全監視システム",
    "phase0": {
      "vision": "原子力発電所の安全パラメータをリアルタイム監視し、異常兆候を早期検知・自動対応するシステム。緊急停炉判断を含む安全機能を担う。",
      "stakeholders": "原子力規制委員会、発電所運転員、地域住民、電力会社",
      "priority": "炉心損傷ゼロ。安全系の誤動作は許容するが安全機能の失敗は許容しない"
    },
    "phase1": {
      "C": [
        {"id": "C1", "content": "緊急停炉（SCRAM）は炉心安全パラメータ逸脱時に自動起動しなければならない"},
        {"id": "C2", "content": "安全系は多重・多様性の原則に基づき設計する"},
        {"id": "C3", "content": "規制機関への自動報告は事象発生から15分以内に行う"},
        {"id": "C4", "content": "運転員の判断は最終的に機械判断を上書きできる"},
        {"id": "C5", "content": "共通原因故障を防ぐため物理的分離を維持する"},
        {"id": "C6", "content": "安全解析コードによる炉心状態計算を毎秒実行する"}
      ],
      "H": [
        {"id": "H1", "basis": "C1,C6", "content": "SCRAM閾値は保守的マージンを20%加算して設定すべき", "refutation": "過剰な停炉が発電信頼性に重大影響を与える場合"},
        {"id": "H2", "basis": "C2", "content": "センサー系は最低4チャンネルの2-of-4論理で判断すべき", "refutation": "高信頼性センサーが実証された場合"},
        {"id": "H3", "basis": "C5", "content": "デジタル制御系と計装は物理的に2m以上分離すべき", "refutation": "電磁シールド技術で分離要件を代替できる場合"},
        {"id": "H4", "basis": "外部知識", "content": "過渡解析シミュレーションは12時間ごとに更新すべき", "refutation": "リアルタイム物理モデルが実用化された場合"},
        {"id": "H5", "basis": "C4", "content": "運転員介入のタイムウィンドウは自動判断後30秒を確保すべき", "refutation": "過渡事象の進展が30秒を超えない場合"}
      ]
    },
