  {
    "scenario_id": 332,
    "project": "アルゴリズム取引プラットフォーム",
    "phase0": {
      "vision": "複数取引所で高頻度アルゴリズム取引を実行し、リスク管理とコンプライアンスを自動化するプラットフォーム。ミリ秒単位の判断で収益最大化を図る。",
      "stakeholders": "機関投資家、コンプライアンス部門、取引所、金融規制当局",
      "priority": "システミックリスクの防止と規制遵守が最優先。収益はその枠内で最大化"
    },
    "phase1": {
      "C": [
        {"id": "C1", "content": "1日あたりの最大損失額（VaR）を超えた場合は全ポジションを自動清算する"},
        {"id": "C2", "content": "市場操作とみなされる取引パターンは禁止する"},
        {"id": "C3", "content": "全取引履歴は規制当局への提出のため7年間保存する"},
        {"id": "C4", "content": "フラッシュクラッシュ検知時は自動的に取引を停止する"},
        {"id": "C5", "content": "リスクリミットは人間のリスク管理者のみが変更できる"}
      ],
      "H": [
        {"id": "H1", "basis": "C1", "content": "VaR計算は99%信頼区間、10日保有期間で標準化すべき", "refutation": "テールリスクイベントでVaRが実損を著しく過小評価する場合"},
        {"id": "H2", "basis": "C4", "content": "価格変動が過去1分間の標準偏差の5倍を超えた場合をフラッシュクラッシュと定義すべき", "refutation": "正常な急騰局面でも誤検知する場合"},
        {"id": "H3", "basis": "C2", "content": "同一銘柄の両建て回転売買は3回連続で検知した場合に警告すべき", "refutation": "ヘッジ目的の正当な取引パターンと区別できない場合"},
        {"id": "H4", "basis": "外部知識", "content": "取引アルゴリズムのパラメータ最適化は週次バックテストで評価すべき", "refutation": "市場レジーム変化が週次より速い頻度で発生する場合"}
      ]
    },
    "phase2": {
