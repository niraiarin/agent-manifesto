    },
    "phase1": {
      "C": [
        {"id": "C1", "content": "緊急車両（救急・消防・警察）の接近時は最優先で青信号経路を確保する"},
        {"id": "C2", "content": "歩行者・自転車の横断時間は物理的最低限以上を常に保証する"},
        {"id": "C3", "content": "信号制御は道路交通法の信号サイクル規定に準拠する"},
        {"id": "C4", "content": "システム障害時は固定サイクルにフォールバックする"},
        {"id": "C5", "content": "交差点ごとの渋滞・停車時間データをリアルタイム収集する"},
        {"id": "C6", "content": "最適化の変更は段階的に適用し急激な信号変更を避ける"}
      ],
      "H": [
        {"id": "H1", "basis": "C1", "content": "緊急車両検知はADS-B + GPS + 路側センサー3重系が最も信頼性が高い", "refutation": "5G V2X通信が普及した場合"},
        {"id": "H2", "basis": "C5", "content": "強化学習（PPO）による適応的信号制御が静的最適化より15%以上効率的", "refutation": "訓練データの偏りが現実の交通パターンと乖離する場合"},
