  {
    "phase0": {
      "vision": "損害保険の保険金請求に対してAIが損害額を自動査定するシステム。書類・写真・現場データを統合解析し、査定精度向上と処理時間短縮を実現する。",
      "stakeholders": "保険契約者、損害査定員、保険会社経営層、金融庁",
      "priority": "公正・公平な査定が最優先。自動化によるスピード化は公正性を損なわない範囲で追求する"
    },
    "phase1": {
      "C": [
        {"id": "C1", "content": "保険業法および金融庁ガイドラインに準拠した査定プロセスを維持する"},
        {"id": "C2", "content": "査定根拠は被保険者に説明可能な形で文書化する"},
        {"id": "C3", "content": "一定金額以上の案件・異議申し立て案件は必ず人間が最終審査する"},
        {"id": "C4", "content": "査定モデルに性別・居住地域・民族属性等による差別的バイアスを含まない"},
        {"id": "C5", "content": "保険金不正請求の検出精度を向上させる"},
        {"id": "C6", "content": "個人情報・医療情報の取扱いは個人情報保護法に準拠する"}
      ],
      "H": [
        {"id": "H1", "basis": "C2", "content": "SHAPベースの説明可能AI手法で査定根拠を自然言語に変換できる", "refutation": "複雑モデルでSHAP値の解釈が直感に反する場合"},
        {"id": "H2", "basis": "C4", "content": "公平性制約付き学習（Fairness-aware ML）でバイアスを95%削減できる", "refutation": "公平性制約がモデル精度と根本的にトレードオフになる場合"},
        {"id": "H3", "basis": "C5", "content": "異常検知アルゴリズムと過去の不正パターンDBの組み合わせが最も不正検出率が高い", "refutation": "新手の不正手口がパターンから乖離する場合"},
        {"id": "H4", "basis": "C3", "content": "査定額の95%タイル値を自動化の上限閾値とすることでリスクを限定できる", "refutation": "高額案件でも定型的な損害が多い保険種類の場合"},
        {"id": "H5", "basis": "C1,C6", "content": "フェデレーテッドラーニングで医療情報を集中管理せずにモデル訓練できる", "refutation": "通信コスト・同期遅延がシステム要件を超える場合"}
      ]
    },
