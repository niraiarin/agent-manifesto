      "note": "ForgeCode ランタイムに組み込み済み"
    },
    {
      "axiomId": "FC9",
      "designPrinciple": "D18",
      "claim": "3 組込みエージェント + Task 並列委譲でマルチエージェント協調",
      "implements": [".forge/agents/"],
      "dependsOnAssumptions": ["FC-C6", "FC-H4"]
    },
    {
      "axiomId": "FC-D3",
      "designPrinciple": "D3",
      "claim": "6 種のライフサイクルイベント + tracing handler が可観測性を提供",
      "implements": [],
      "dependsOnAssumptions": [],
      "note": "ForgeCode ランタイムに組み込み"
    },
    {
      "axiomId": "FC-D16",
      "designPrinciple": "D16",
      "claim": "Tiered thinking + semantic search が情報関連性を最適化",
      "implements": [],
