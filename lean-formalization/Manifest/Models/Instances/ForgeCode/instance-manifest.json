      "implements": [".forge.toml", "AGENTS.md", ".forge/skills/", ".forge/agents/"],
      "dependsOnAssumptions": ["FC-C4"]
    },
    {
      "axiomId": "FC8",
      "designPrinciple": "D15",
      "claim": "Doom loop 検出 + mandatory todo + guardrails がハーネスエンジニアリングを実装",
      "implements": [],
