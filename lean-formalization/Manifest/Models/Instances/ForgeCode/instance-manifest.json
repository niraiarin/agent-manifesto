{
  "version": "1.0.0",
  "system": {
    "name": "forgecode",
    "leanModule": "Manifest.Models.Instances.ForgeCode",
    "description": "ForgeCode (Antinomy) の条件付き設計基礎。D1-D18 を ForgeCode プリミティブにマッピング。"
  },
  "assumptions": [
    {
      "id": "FC-C1",
      "type": "C",
      "content": "L1 制約はポリシーエンジン (Deny) + AGENTS.md 規範で強制する",
      "sourceRef": "crates/forge_domain/src/policies/engine.rs",
      "lastVerified": "2026-04-09",
      "reviewInterval": 90,
      "derivedFromPDs": ["PD-1", "PD-2", "PD-3", "PD-74"]
    },
    {
      "id": "FC-C2",
      "type": "C",
      "content": "P2 検証は sage エージェント (read-only) への Task 委譲で行う",
      "sourceRef": "crates/forge_repo/src/agents/sage.md",
      "lastVerified": "2026-04-09",
      "reviewInterval": 90,
      "derivedFromPDs": ["PD-11", "PD-12", "PD-13"]
    },
    {
      "id": "FC-C3",
      "type": "C",
      "content": "規範的指針は AGENTS.md に配置する",
      "sourceRef": "https://forgecode.dev/docs/custom-rules/",
      "lastVerified": "2026-04-09",
      "reviewInterval": 180,
      "derivedFromPDs": ["PD-74", "PD-75"]
    },
    {
      "id": "FC-C4",
      "type": "C",
      "content": "スキルは .forge/skills/<name>/SKILL.md に永続化する (Claude Code 互換)",
      "sourceRef": "https://forgecode.dev/docs/skills/",
      "lastVerified": "2026-04-09",
      "reviewInterval": 180,
      "derivedFromPDs": ["PD-51", "PD-52", "PD-56"]
    },
    {
      "id": "FC-C5",
      "type": "C",
      "content": "Plan-then-Act ワークフローで計画と実行を分離する (muse → review → forge)",
      "sourceRef": "https://forgecode.dev/docs/plan-and-act-guide/",
      "lastVerified": "2026-04-09",
      "reviewInterval": 90,
      "derivedFromPDs": ["PD-47", "PD-11"]
    },
    {
      "id": "FC-C6",
      "type": "C",
      "content": "D18 の実現として Task tool によるエージェント間委譲を使用する",
      "sourceRef": "crates/forge_domain/src/tools/catalog.rs",
      "lastVerified": "2026-04-09",
      "reviewInterval": 90,
      "derivedFromPDs": ["PD-14", "PD-15"]
    },
    {
      "id": "FC-C7",
      "type": "C",
      "content": "Git worktree sandbox で実験的変更を隔離する",
      "sourceRef": "crates/forge_main/src/sandbox.rs",
      "lastVerified": "2026-04-09",
      "reviewInterval": 90,
      "derivedFromPDs": ["PD-59", "PD-60"]
    },
    {
      "id": "FC-H1",
      "type": "H",
      "content": "ポリシーエンジンの Deny はエージェントがバイパスできない (ランタイム強制)",
      "sourceRef": "crates/forge_domain/src/policies/engine.rs",
      "lastVerified": "2026-04-09",
      "reviewInterval": 60,
      "refutation": "ForgeCode がポリシー評価をオプトアウト可能にした場合",
      "derivedFromPDs": ["PD-1", "PD-3", "PD-4"]
    },
    {
      "id": "FC-H2",
      "type": "H",
      "content": "sage エージェントは構造的に書き込み不可 (ツールホワイトリスト制限)",
      "sourceRef": "crates/forge_repo/src/agents/sage.md",
      "lastVerified": "2026-04-09",
      "reviewInterval": 60,
      "refutation": "sage に write/shell/patch ツールが追加された場合",
      "derivedFromPDs": ["PD-12", "PD-13", "PD-18"]
    },
    {
      "id": "FC-H3",
      "type": "H",
      "content": "Doom loop 検出がランタイムレベルで非収束を検知し介入する",
      "sourceRef": "crates/forge_app/src/hooks/doom_loop.rs",
      "lastVerified": "2026-04-09",
      "reviewInterval": 60,
      "refutation": "doom loop 検出が削除された場合",
      "derivedFromPDs": ["PD-42", "PD-43"]
    },
    {
      "id": "FC-H4",
      "type": "H",
      "content": "Task tool calls のみ並列実行、他のツールは逐次",
      "sourceRef": "crates/forge_app/src/orch.rs",
      "lastVerified": "2026-04-09",
      "reviewInterval": 60,
      "refutation": "全ツールが並列実行されるようになった場合",
      "derivedFromPDs": ["PD-15", "PD-14"]
    },
    {
      "id": "FC-H5",
      "type": "H",
      "content": "コンテキスト圧縮は tool-call/result ペアの原子性を保証する",
      "sourceRef": "crates/forge_domain/src/compact/",
      "lastVerified": "2026-04-09",
      "reviewInterval": 60,
      "refutation": "圧縮がペア原子性を保証しなくなった場合",
      "derivedFromPDs": ["PD-33", "PD-34", "PD-35"]
    },
    {
      "id": "FC-H6",
      "type": "H",
      "content": "Mandatory todo_write がタスク完了率を大幅に改善する (38% → 66%)",
      "sourceRef": "https://forgecode.dev/blog/benchmarks-dont-matter/",
      "lastVerified": "2026-04-09",
      "reviewInterval": 60,
      "refutation": "todo_write が任意になった場合",
      "derivedFromPDs": ["PD-44", "PD-45", "PD-46"]
    },
    {
      "id": "FC-H7",
      "type": "H",
      "content": "Tiered thinking policy: high (1-10) → low (11+) → high (verification)",
      "sourceRef": "https://forgecode.dev/blog/benchmarks-dont-matter/",
      "lastVerified": "2026-04-09",
      "reviewInterval": 60,
      "refutation": "全ターンで均一な推論深度に変更された場合",
      "derivedFromPDs": ["PD-48", "PD-19"]
    },
    {
      "id": "FC-H8",
      "type": "H",
      "content": "ファイルスナップショットにより変更前状態が保存され Undo が可能",
      "sourceRef": "crates/forge_domain/src/snapshot.rs",
      "lastVerified": "2026-04-09",
      "reviewInterval": 90,
      "refutation": "スナップショット機構が削除された場合",
      "derivedFromPDs": ["PD-81", "PD-26"]
    },
    {
      "id": "FC-H9",
      "type": "H",
      "content": "ツール名が LLM 訓練データパターンに意図的に合わせられ、ランタイム補正層が命名不一致を吸収",
      "sourceRef": "https://forgecode.dev/blog/benchmarks-dont-matter/",
      "lastVerified": "2026-04-09",
      "reviewInterval": 60,
      "refutation": "訓練データ整合方針が放棄された場合",
      "derivedFromPDs": ["PD-23", "PD-24"]
    },
    {
      "id": "FC-H10",
      "type": "H",
      "content": "設計哲学 'Simple Over Easy' — アーキテクチャ制約で解法を一意に絞り品質確保",
      "sourceRef": "https://forgecode.dev/blog/simple-is-not-easy/",
      "lastVerified": "2026-04-09",
      "reviewInterval": 180,
      "refutation": "制約より柔軟性を優先する設計転換があった場合",
      "derivedFromPDs": ["PD-12", "PD-18", "PD-23", "PD-42"]
    },
    {
      "id": "FC-H11",
      "type": "H",
      "content": "エージェントごとに異なるプロバイダ/モデル設定が可能。sage を異なるモデルファミリで動かすと evaluatorIndependent=true",
      "sourceRef": "crates/forge_domain/src/agent.rs",
      "lastVerified": "2026-04-09",
      "reviewInterval": 90,
      "refutation": "エージェントごとのプロバイダ/モデル設定が廃止された場合",
      "derivedFromPDs": ["PD-57", "PD-58"]
    }
  ],
