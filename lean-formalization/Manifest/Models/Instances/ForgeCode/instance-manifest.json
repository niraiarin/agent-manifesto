      "dependsOnAssumptions": ["FC-C1", "FC-H1"]
    },
    {
      "axiomId": "FC2",
      "designPrinciple": "D1",
      "claim": "sage エージェントは構造的 read-only 強制",
      "implements": [".forge/agents/sage.md"],
      "dependsOnAssumptions": ["FC-C2", "FC-H2"]
    },
    {
      "axiomId": "FC3",
      "designPrinciple": "D1",
