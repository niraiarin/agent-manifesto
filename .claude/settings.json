{
  "$schema": "https://claude.ai/schemas/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf *)",
      "Bash(rm -rf .)",
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(git reset --hard)",
      "Bash(git clean -fd)",
      "Bash(git checkout -- .)",
      "Bash(chmod 777)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(eval *)"
    ],
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/nirarin/work/agent-manifesto/.claude/hooks/l1-safety-check.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/nirarin/work/agent-manifesto/.claude/hooks/l1-test-tampering-check.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/nirarin/work/agent-manifesto/.claude/hooks/l1-test-tampering-check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git add *)",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/nirarin/work/agent-manifesto/.claude/hooks/l1-secret-check.sh"
          }
        ]
      }
    ]
  }
}
